# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# OpenAI API key — REQUIRED and the only key. Used by generation (gpt-5.2, both
# panels), RAG embeddings (text-embedding-3-small), and the optional judge
# (gpt-5-mini). Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
