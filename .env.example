# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Anthropic API key — required for generation (both RAG and CAG panels).
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI key — required for embeddings in the RAG panel.
# Obtain from https://dash.voyageai.com/
VOYAGE_API_KEY=pa-...
